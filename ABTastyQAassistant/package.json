{
  "name": "@abtasty/qa-assistant-react-native",
  "version": "1.0.0",
  "description": "QA Assistant for ABTasty Feature Experimentation in React Native",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "prepublishOnly": "yarn build",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --watchAll=false"
  },
  "keywords": [
    "abtasty",
    "flagship",
    "qa",
    "testing",
    "react-native",
    "feature-flags",
    "ab-testing"
  ],
  "author": "ABTasty",
  "license": "Apache-2.0",
  "peerDependencies": {
    "@flagship.io/react-native-sdk": ">=5.1.0",
    "react": ">=18.0.0",
    "react-native": ">=0.70.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flagship-io/abtasty-qa-assistant-react-native.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "packageManager": "yarn@4.11.0+sha512.4e54aeace9141df2f0177c266b05ec50dc044638157dae128c471ba65994ac802122d7ab35bcd9e81641228b7dcf24867d28e750e0bcae8a05277d600008ad54",
  "dependencies": {
    "@react-navigation/material-top-tabs": "^7.4.11",
    "@react-navigation/native": "^7.1.26",
    "react-native-pager-view": "^8.0.0",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-svg": "^15.15.1",
    "react-native-tab-view": "^4.2.2"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^12.5.2",
    "@types/jest": "^30.0.0",
    "@types/react-test-renderer": "19",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "react-test-renderer": "19",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
